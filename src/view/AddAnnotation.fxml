<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="420.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AddAnnotationController">

    <!-- CONTENIDO -->
    <center>
        <VBox prefWidth="200.0" spacing="14.0">
         <Separator prefWidth="200.0" />

            <!-- Volver -->
            <HBox alignment="CENTER_LEFT">
                <Button onAction="#handleBack" styleClass="nav-button" stylesheets="@../resources/styles.css" text="← Volver" />
            <Region prefHeight="41.0" prefWidth="120.0" />
   
               <!-- Título -->
               <Label style="-fx-font-size:20; -fx-font-weight:bold;" styleClass="screen-title" stylesheets="@../resources/styles.css" text="Añadir Anotación" />
            </HBox>

            <!-- Tipo de anotación -->
            <Label style="-fx-font-weight:bold;" text="Tipo de anotación" />
            <HBox alignment="CENTER_LEFT" spacing="16">
                <RadioButton fx:id="rbPoint" onAction="#handleTypeChange" selected="true" text="Punto">
               <toggleGroup>
                  <ToggleGroup fx:id="tipoGroup" />
               </toggleGroup></RadioButton>
                <RadioButton fx:id="rbText" onAction="#handleTypeChange" text="Texto" toggleGroup="$tipoGroup" />
                <RadioButton fx:id="rbLine" onAction="#handleTypeChange" text="Línea" toggleGroup="$tipoGroup" />
                <RadioButton fx:id="rbCircle" onAction="#handleTypeChange" text="Círculo" toggleGroup="$tipoGroup" />
            </HBox>

            <!-- Texto -->
            <Label styleClass="floating-label" stylesheets="@../resources/styles.css" text="Texto:" />
            <TextField fx:id="txtAnnotationText" promptText="Escribe una descripción..." styleClass="custom-textfield" stylesheets="@../resources/styles.css" VBox.vgrow="ALWAYS" />

            <!-- Color y Grosor -->
            <HBox alignment="CENTER_LEFT" spacing="24">

                <!-- Color -->
                <VBox spacing="4">
                    <Label style="-fx-font-weight:bold;" text="Color" />
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <TextField fx:id="txtColor" prefWidth="90" styleClass="custom-textfield" text="#E74C3C" />
                        <ColorPicker fx:id="colorPicker" onAction="#handleColorPickerChange" />
                    </HBox>
                </VBox>

                <!-- Grosor -->
                <VBox spacing="4">
                    <Label style="-fx-font-weight:bold;" text="Grosor del trazo" />
                    <HBox alignment="CENTER_LEFT" spacing="6">
                  <ComboBox fx:id="comboStrokeWidth" editable="true" prefHeight="26.0" prefWidth="85.0" />
                        <Label text="px" />
                    </HBox>
                </VBox>

            </HBox>

            <!-- Botones -->
            <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 10 0 0 0;">
                <Button onAction="#handleCancel" styleClass="nav-button" stylesheets="@../resources/styles.css" text="CANCELAR" />
                <Button onAction="#handleSave" styleClass="import-button" stylesheets="@../resources/styles.css" text="GUARDAR" />
            </HBox>
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" />
         </padding>

        </VBox>
    </center>
   <top>
      <HBox maxHeight="-Infinity" prefHeight="60.0" prefWidth="600.0" spacing="10.0" BorderPane.alignment="CENTER_LEFT">
         <children>
            <Label prefHeight="44.0" prefWidth="242.0" styleClass="screen-title" stylesheets="@../resources/styles.css" text="Running la Safor" HBox.hgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Region prefHeight="44.0" prefWidth="22.0" HBox.hgrow="ALWAYS" />
            <Label fx:id="lblUser" prefHeight="44.0" prefWidth="122.0" styleClass="user-name" stylesheets="@../resources/styles.css" text="usuarioejemplo" HBox.hgrow="ALWAYS" />
            <ImageView fx:id="imgUser" fitHeight="47.0" fitWidth="44.0" pickOnBounds="true" preserveRatio="true" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleLogOut" prefHeight="42.0" prefWidth="134.0" styleClass="top-action-button" stylesheets="@../resources/styles.css" text="Cerrar Sesión" HBox.hgrow="ALWAYS" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding></HBox>
   </top>

</BorderPane>
