<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0"
            prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ActivityDetailsController"
            stylesheets="@../resources/styles.css">

    <top>
        <VBox spacing="8.0">
            <padding>
                <Insets top="14.0" right="24.0" bottom="6.0" left="24.0"/>
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <children>
                        <Button fx:id="backButton"
                                text="← Volver"
                                onAction="#handleBack"
                                styleClass="nav-button"/>

                        <Label fx:id="titleLabel"
                               text="Running la Safor - Activity"
                               styleClass="screen-title"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="usernameLabel"
                               text="usuario"
                               styleClass="user-name"/>

                        <ImageView fx:id="avatarImageView"
                                   fitHeight="42"
                                   fitWidth="42"
                                   preserveRatio="true">
                            <image>
                                <Image url="@../resources/logo.png"/>
                            </image>
                        </ImageView>

                        <Button fx:id="logoutButton"
                                text="Cerrar sesión"
                                onAction="#handleLogout"
                                styleClass="top-action-button"/>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <children>
                        <Label text="Zoom"/>
                        <Button text="-" onAction="#handleZoomOut"/>
                        <Slider fx:id="zoomSlider"
                                min="0.5"
                                max="2.0"
                                value="1.0"
                                prefWidth="220"/>
                        <Button text="+" onAction="#handleZoomIn"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <HBox spacing="12.0">
            <padding>
                <Insets top="6.0" right="24.0" bottom="8.0" left="24.0"/>
            </padding>

            <children>
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Mapa y trazado"
                               styleClass="section-title"/>

                        <ScrollPane fx:id="mapScrollPane"
                                    pannable="false"
                                    fitToWidth="false"
                                    fitToHeight="false"
                                    HBox.hgrow="ALWAYS">
                            <content>
                                <StackPane fx:id="mapContentPane"
                                           prefWidth="900"
                                           prefHeight="560"/>
                            </content>
                        </ScrollPane>

                        <Label fx:id="mapStatusLabel"
                               text=""
                               styleClass="summary-label"/>
                    </children>
                </VBox>

                <VBox spacing="12.0"
                      minWidth="360"
                      prefWidth="360"
                      maxWidth="360">
                    <children>
                        <Label text="Estadísticas"
                               styleClass="section-title"/>

                        <VBox spacing="10.0">
                            <children>
                                <HBox spacing="10">
                                    <children>
                                        <Label text="Distancia:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="distanceValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>

                                <HBox spacing="10">
                                    <children>
                                        <Label text="Duración:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="durationValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>

                                <HBox spacing="10">
                                    <children>
                                        <Label text="Velocidad media:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="speedValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>

                                <HBox spacing="10">
                                    <children>
                                        <Label text="Ritmo medio:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="paceValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>

                                <HBox spacing="10">
                                    <children>
                                        <Label text="Desnivel +:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="gainValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>

                                <HBox spacing="10">
                                    <children>
                                        <Label text="Desnivel -:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="lossValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>

                                <HBox spacing="10">
                                    <children>
                                        <Label text="Altitud mín.:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="minElevationValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>

                                <HBox spacing="10">
                                    <children>
                                        <Label text="Altitud máx.:"
                                               styleClass="stat-label"/>
                                        <Label fx:id="maxElevationValueLabel"
                                               styleClass="stat-value"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="Anotaciones"
                                       styleClass="section-title"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button fx:id="addAnnotationButton"
                                        text="+ Añadir"
                                        onAction="#handleAddAnnotation"
                                        styleClass="import-button"/>
                            </children>
                        </HBox>

                        <TableView fx:id="annotationTable"
                                   prefHeight="300"
                                   minHeight="300"
                                   maxHeight="300"
                                   styleClass="activities-table">
                            <columns>
                                <TableColumn fx:id="annotationTypeColumn"
                                             text="Tipo"
                                             prefWidth="85"/>
                                <TableColumn fx:id="annotationTextColumn"
                                             text="Texto"
                                             prefWidth="240"/>
                                <TableColumn fx:id="annotationColorColumn"
                                             text="Color"
                                             prefWidth="90"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>

</BorderPane>