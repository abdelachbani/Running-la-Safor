<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0"
            prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AccumulatedController"
            stylesheets="@../resources/styles.css">

    <top>
        <VBox spacing="8.0">
            <padding>
                <Insets top="14.0" right="24.0" bottom="6.0" left="24.0"/>
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <children>
                        <Button fx:id="backButton"
                                text="← Volver"
                                onAction="#handleBack"
                                styleClass="profile-back-button"/>

                        <Label fx:id="titleLabel"
                               text="Running la Safor - Acumulado"
                               styleClass="screen-title"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Label fx:id="usernameLabel"
                                       text="usuario"
                                       styleClass="user-name"/>

                                <ImageView fx:id="avatarImageView"
                                           fitHeight="42"
                                           fitWidth="42"
                                           preserveRatio="true">
                                    <image>
                                        <Image url="@../resources/logo.png"/>
                                    </image>
                                </ImageView>

                                <Button fx:id="logoutButton"
                                        text="Cerrar sesión"
                                        onAction="#handleLogout"
                                        styleClass="profile-top-button"/>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="14.0">
            <padding>
                <Insets top="6.0" right="24.0" bottom="8.0" left="24.0"/>
            </padding>

            <children>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label text="Resumen del periodo"
                               styleClass="section-title"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="statusLabel"
                               text=""
                               styleClass="summary-label"/>

                        <Button fx:id="periodButton"
                                text="Marzo 2026"
                                onAction="#handlePeriodSelection"
                                styleClass="import-button"/>
                    </children>
                </HBox>

                <FlowPane hgap="10.0" vgap="10.0">
                    <children>
                        <Label fx:id="activitiesCountLabel"
                               text="Actividades: 0"
                               styleClass="summary-label"/>

                        <Label fx:id="totalTimeLabel"
                               text="Tiempo total: -"
                               styleClass="summary-label"/>

                        <Label fx:id="totalDistanceLabel"
                               text="Distancia total: -"
                               styleClass="summary-label"/>

                        <Label fx:id="totalGainLabel"
                               text="Ascenso total: -"
                               styleClass="summary-label"/>

                        <Label fx:id="totalLossLabel"
                               text="Descenso total: -"
                               styleClass="summary-label"/>
                    </children>
                </FlowPane>

                <Label text="Actividades del periodo"
                       styleClass="section-title"/>

                <ScrollPane fitToWidth="true"
                            fitToHeight="true">

                    <content>
                        <TableView fx:id="monthlyActivitiesTable"
                                   prefHeight="420.0"
                                   styleClass="activities-table">

                            <columns>
                                <TableColumn fx:id="nameColumn"
                                             text="Actividad"
                                             prefWidth="380.0"/>

                                <TableColumn fx:id="dateColumn"
                                             text="Fecha"
                                             prefWidth="170.0"/>

                                <TableColumn fx:id="distanceColumn"
                                             text="Distancia"
                                             prefWidth="130.0"/>

                                <TableColumn fx:id="durationColumn"
                                             text="Duración"
                                             prefWidth="120.0"/>

                                <TableColumn fx:id="gainColumn"
                                             text="Ascenso"
                                             prefWidth="110.0"/>

                                <TableColumn fx:id="lossColumn"
                                             text="Descenso"
                                             prefWidth="110.0"/>
                            </columns>

                        </TableView>
                    </content>

                </ScrollPane>

            </children>
        </VBox>
    </center>

</BorderPane>